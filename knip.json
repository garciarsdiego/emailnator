{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "supabase/functions/*/index.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "supabase/functions/**/*.ts",
    "*.{ts,js}"
  ],
  "ignoreExportsUsedInFile": true,
  "ignore": ["src/integrations/supabase/types.ts"],
  "ignoreDependencies": [
    "sanitize-html",
    "@types/sanitize-html"
  ]
}
