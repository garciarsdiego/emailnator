# Supabase provides SUPABASE_URL, SUPABASE_ANON_KEY and
# SUPABASE_SERVICE_ROLE_KEY to deployed Edge Functions automatically.

# Public application origins (comma-separated ALLOWED_ORIGINS is optional).
APP_ORIGIN=https://app.example.com
ALLOWED_ORIGINS=https://www.example.com

# AI and site analysis providers.
LOVABLE_API_KEY=replace-with-secret
FIRECRAWL_API_KEY=replace-with-secret
AI_MODEL=google/gemini-2.5-flash

# Stripe server-side secrets.
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
STRIPE_TRIAL_DAYS=7

# Optional catalog overrides. The current v1 IDs remain the code defaults for
# backward compatibility, but production should set these explicitly.
STRIPE_STARTER_PRICE_ID=price_replace
STRIPE_STARTER_PRODUCT_ID=prod_replace
STRIPE_PRO_PRICE_ID=price_replace
STRIPE_PRO_PRODUCT_ID=prod_replace
STRIPE_PACK10_PRICE_ID=price_replace
STRIPE_PACK10_PRODUCT_ID=prod_replace
STRIPE_PACK50_PRICE_ID=price_replace
STRIPE_PACK50_PRODUCT_ID=prod_replace
STRIPE_PACK150_PRICE_ID=price_replace
STRIPE_PACK150_PRODUCT_ID=prod_replace
